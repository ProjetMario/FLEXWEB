generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  TRIAL
}

enum PageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIAL
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  memberships   Membership[]
  accounts      Account[]
  sessions      Session[]
  auditLogs     AuditLog[]
  notifications Notification[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Organization {
  id           String             @id @default(uuid())
  slug         String             @unique
  name         String
  businessType String
  status       OrganizationStatus @default(TRIAL)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  memberships          Membership[]
  websites             Website[]
  domains              Domain[]
  media                Media[]
  pages                Page[]
  navigationItems      NavigationItem[]
  services             Service[]
  products             Product[]
  projects             Project[]
  teamMembers          TeamMember[]
  testimonials         Testimonial[]
  articles             Article[]
  categories           Category[]
  faqs                 FAQ[]
  events               Event[]
  forms                Form[]
  formSubmissions      FormSubmission[]
  leads                Lead[]
  appointments         Appointment[]
  businessHours        BusinessHours[]
  socialLinks          SocialLink[]
  subscriptions        Subscription[]
  auditLogs            AuditLog[]
  notifications        Notification[]
  organizationFeatures OrganizationFeature[]
  websiteSettings      WebsiteSettings?
  seoSettings          SEOSettings?

  @@index([slug])
  @@index([businessType])
}

model Membership {
  id             String   @id @default(uuid())
  organizationId String
  userId         String
  role           UserRole @default(EDITOR)
  invitedBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

model Website {
  id            String   @id @default(uuid())
  organizationId String
  templateId     String?
  name           String
  primaryDomain  String?
  faviconUrl     String?
  isPublished    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  template        Template?         @relation(fields: [templateId], references: [id])
  pages           Page[]
  navigationItems NavigationItem[]
  websiteSettings WebsiteSettings?
  seoSettings     SEOSettings?

  @@index([organizationId])
}

model WebsiteSettings {
  id              String   @id @default(uuid())
  organizationId  String   @unique
  websiteId       String?  @unique
  brandColor      String?
  secondaryColor  String?
  fontHeading     String?
  fontBody        String?
  logoUrl         String?
  contactEmail    String?
  contactPhone    String?
  address         String?
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  website      Website?     @relation(fields: [websiteId], references: [id], onDelete: SetNull)
}

model SEOSettings {
  id               String   @id @default(uuid())
  organizationId   String   @unique
  websiteId        String?  @unique
  defaultTitle     String?
  defaultDescription String?
  ogImageUrl       String?
  twitterHandle    String?
  robotsTxt        String?
  sitemapEnabled   Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  website      Website?     @relation(fields: [websiteId], references: [id], onDelete: SetNull)
}

model Domain {
  id             String    @id @default(uuid())
  organizationId String
  domain         String    @unique
  isCustom       Boolean   @default(false)
  isPrimary      Boolean   @default(false)
  verifiedAt     DateTime?
  sslConfigured  Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Template {
  id               String   @id @default(uuid())
  name             String
  slug             String   @unique
  category         String
  description      String?
  thumbnailUrl     String?
  defaultPages     Json?
  defaultStyles    Json?
  availableModules Json?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  websites Website[]
}

model Page {
  id              String     @id @default(uuid())
  organizationId  String
  websiteId       String
  slug            String
  title           String
  status          PageStatus @default(DRAFT)
  metaTitle       String?
  metaDescription String?
  ogImageUrl      String?
  isHomepage      Boolean    @default(false)
  publishedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  website      Website     @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  sections     PageSection[]

  @@unique([organizationId, websiteId, slug])
  @@index([organizationId, websiteId])
}

model PageSection {
  id        String   @id @default(uuid())
  pageId    String
  type      String
  config    Json
  order     Int
  isVisible Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
}

model NavigationItem {
  id             String  @id @default(uuid())
  organizationId String
  websiteId      String
  label          String
  href           String
  parentId       String?
  order          Int     @default(0)
  isVisible      Boolean @default(true)

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  website      Website         @relation(fields: [websiteId], references: [id], onDelete: Cascade)
  parent       NavigationItem? @relation("NavigationChildren", fields: [parentId], references: [id])
  children     NavigationItem[] @relation("NavigationChildren")

  @@index([organizationId, websiteId])
}

model Media {
  id             String   @id @default(uuid())
  organizationId String
  filename       String
  url            String
  mimeType       String
  sizeInBytes    Int
  width          Int?
  height         Int?
  altText        String?
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Service {
  id             String   @id @default(uuid())
  organizationId String
  title          String
  description    String?
  imageUrl       String?
  price          String?
  isVisible      Boolean  @default(true)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Product {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  description    String?
  imageUrl       String?
  price          String?
  categoryId     String?
  isVisible      Boolean  @default(true)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     Category?    @relation(fields: [categoryId], references: [id])

  @@index([organizationId])
}

model Project {
  id             String    @id @default(uuid())
  organizationId String
  title          String
  description    String?
  imageUrl       String?
  clientName     String?
  completionDate DateTime?
  isVisible      Boolean   @default(true)
  order          Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model TeamMember {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  role           String?
  bio            String?
  imageUrl       String?
  email          String?
  order          Int      @default(0)
  isVisible      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Testimonial {
  id             String   @id @default(uuid())
  organizationId String
  authorName     String
  authorRole     String?
  content        String
  imageUrl       String?
  rating         Int?
  isVisible      Boolean  @default(true)
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Article {
  id             String     @id @default(uuid())
  organizationId String
  title          String
  slug           String
  excerpt        String?
  content        Json?
  coverImageUrl  String?
  categoryId     String?
  status         PageStatus @default(DRAFT)
  publishedAt    DateTime?
  authorId       String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     Category?    @relation(fields: [categoryId], references: [id])

  @@unique([organizationId, slug])
  @@index([organizationId])
}

model Category {
  id             String @id @default(uuid())
  organizationId String
  name           String
  slug           String
  type           String
  order          Int    @default(0)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products     Product[]
  articles     Article[]
  events       Event[]

  @@unique([organizationId, slug, type])
  @@index([organizationId])
}

model FAQ {
  id             String   @id @default(uuid())
  organizationId String
  question       String
  answer         String
  order          Int      @default(0)
  isVisible      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Event {
  id             String   @id @default(uuid())
  organizationId String
  title          String
  description    String?
  startDate      DateTime
  endDate        DateTime?
  location       String?
  imageUrl       String?
  categoryId     String?
  isVisible      Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category     Category?    @relation(fields: [categoryId], references: [id])
}

model Form {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  fields         Json
  notifyEmails   String[]
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  submissions  FormSubmission[]
}

model FormSubmission {
  id             String   @id @default(uuid())
  organizationId String
  formId         String
  data           Json
  status         String   @default("new")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  form         Form         @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([organizationId, formId])
}

model Lead {
  id             String   @id @default(uuid())
  organizationId String
  name           String?
  email          String
  phone          String?
  message        String?
  source         String?
  status         String   @default("new")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model Appointment {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  email          String
  phone          String?
  date           DateTime
  notes          String?
  status         String   @default("pending")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model BusinessHours {
  id             String  @id @default(uuid())
  organizationId String
  dayOfWeek      Int
  openTime       String?
  closeTime      String?
  isClosed       Boolean @default(false)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, dayOfWeek])
}

model SocialLink {
  id             String @id @default(uuid())
  organizationId String
  platform       String
  url            String
  order          Int    @default(0)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model Feature {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String?
  category    String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  organizationFeatures OrganizationFeature[]
}

model OrganizationFeature {
  id             String  @id @default(uuid())
  organizationId String
  featureKey     String
  isEnabled      Boolean @default(false)
  settings       Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  feature      Feature      @relation(fields: [featureKey], references: [key])

  @@unique([organizationId, featureKey])
}

model Subscription {
  id             String             @id @default(uuid())
  organizationId String
  plan           String
  status         SubscriptionStatus @default(TRIAL)
  seats          Int                @default(1)
  startDate      DateTime           @default(now())
  endDate        DateTime?
  paymentProvider String?
  externalId     String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
}

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String?
  userId         String?
  action         String
  entityType     String
  entityId       String?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([userId, createdAt])
}

model Notification {
  id             String   @id @default(uuid())
  organizationId String
  userId         String?
  type           String
  title          String
  message        String
  isRead         Boolean  @default(false)
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, userId])
}
