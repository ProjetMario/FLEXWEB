---
import BaseLayout from "../layout/BaseLayout.astro";
import StructuredData from "../components/seo/StructuredData.astro";
import { getEntry, render } from "astro:content";

const entry = await getEntry("services", "creation-site-internet");

if (!entry) {
  throw new Error("Service creation-site-internet not found");
}

const { Content } = await render(entry);
const { data } = entry;

const siteUrl = "https://flex-web.fr";
const canonicalUrl = new URL("creation-site-internet", siteUrl).toString();

const webPageSchema = {
  "@type": "WebPage",
  "@id": canonicalUrl,
  url: canonicalUrl,
  name: data.seoTitle,
  description: data.seoDescription,
  isPartOf: { "@id": siteUrl },
};

const serviceSchema = {
  "@type": "Service",
  name: data.title,
  description: data.description,
  provider: {
    "@type": "Organization",
    name: "FLEX-WEB",
    url: siteUrl,
  },
  areaServed: "France",
};

const breadcrumbSchema = {
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Accueil", item: siteUrl },
    { "@type": "ListItem", position: 2, name: data.title, item: canonicalUrl },
  ],
};

const schemas = [webPageSchema, serviceSchema, breadcrumbSchema];
---

<BaseLayout title={data.seoTitle} description={data.seoDescription}>
  <div class="mx-auto max-w-3xl px-6 py-16 lg:py-24">
    <nav aria-label="Fil d'Ariane" class="mb-8 text-sm" style="color: var(--color-text-muted)">
      <a href="/" class="hover:underline">Accueil</a>
      <span class="mx-2">/</span>
      <span>{data.title}</span>
    </nav>

    <h1 class="text-4xl font-semibold tracking-tight lg:text-5xl" style="color: var(--color-text)">
      {data.title}
    </h1>

    <p class="mt-6 text-lg leading-relaxed" style="color: var(--color-text-muted)">
      {data.description}
    </p>

    <div class="mt-12 space-y-6 text-lg leading-relaxed" style="color: var(--color-text)">
      <Content />
    </div>

    <section class="mt-16">
      <h2 class="text-2xl font-semibold tracking-tight" style="color: var(--color-text)">
        Pour qui ?
      </h2>
      <ul class="mt-4 list-disc space-y-2 pl-6" style="color: var(--color-text)">
        {data.targetAudience.map((item: string) => (
          <li>{item}</li>
        ))}
      </ul>
    </section>

    <section class="mt-16">
      <h2 class="text-2xl font-semibold tracking-tight" style="color: var(--color-text)">
        Nos engagements
      </h2>
      <ul class="mt-4 list-disc space-y-2 pl-6" style="color: var(--color-text)">
        {data.benefits.map((item: string) => (
          <li>{item}</li>
        ))}
      </ul>
    </section>

    <section class="mt-16">
      <h2 class="text-2xl font-semibold tracking-tight" style="color: var(--color-text)">
        Zones desservies
      </h2>
      <div class="mt-4 flex flex-wrap gap-3">
        {data.relatedLocations.map((slug: string) => (
          <a
            href={`/${slug}`}
            class="rounded-full px-4 py-2 text-sm font-medium transition hover:opacity-90"
            style="background-color: var(--color-surface); color: var(--color-text)"
          >
            {slug.replace("creation-site-internet-", "").replace(/-/g, " ")}
          </a>
        ))}
      </div>
    </section>

    <aside class="mt-16 rounded-3xl p-8 text-center" style="background-color: var(--color-surface)">
      <h2 class="text-2xl font-semibold tracking-tight" style="color: var(--color-text)">
        Besoin d'un site internet professionnel ?
      </h2>
      <p class="mt-4" style="color: var(--color-text-muted)">
        Discutons de votre projet et obtenez un devis gratuit.
      </p>
      <a
        href="/contact"
        class="mt-6 inline-flex items-center justify-center rounded-full px-8 py-3 text-base font-medium text-white transition hover:opacity-90"
        style="background-color: var(--color-accent)"
      >
        Demander un devis
      </a>
    </aside>
  </div>

  <StructuredData schemas={schemas} slot="head" />
</BaseLayout>
